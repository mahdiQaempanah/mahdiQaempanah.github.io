---

import HonorsSection from "../components/sections/HonorsSection.astro";
import OlympiadTeachingSection from "../components/sections/OlympiadTeachingSection.astro";
import ProjectsSection from "../components/sections/ProjectsSection.astro";
import PublicationsSection from "../components/sections/PublicationsSection.astro";
import TASection from "../components/sections/TASection.astro";
import WorkSection from "../components/sections/WorkSection.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="Mahdi Qaempanah" description="Computer Scientist & Software Engineer">
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <HonorsSection />
      <WorkSection />
      <OlympiadTeachingSection />
      <TASection />
      <PublicationsSection />
      <ProjectsSection />
    </div>
  </div>
</MainGridLayout>

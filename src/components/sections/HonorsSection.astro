---
import { experience } from "../../data/experience";
import ScrollReveal from "./ScrollReveal.svelte";
---

<section class="mb-12">
  <ScrollReveal client:load delay={0}>
    <h2 class="text-3xl font-bold mb-8 dark:text-neutral-100 border-b border-neutral-200 dark:border-neutral-700 pb-2">Honors & Awards</h2>
  </ScrollReveal>

  {experience.honors.map((honor, index) => (
    <ScrollReveal client:load delay={100 + index * 100}>
      <div class="mb-4 p-4 rounded-xl bg-neutral-50 dark:bg-neutral-800/40 border border-neutral-200 dark:border-neutral-700 shadow-sm flex items-center gap-3">
        <span class="text-2xl">{honor.emoji}</span>
        <div>
          <p class="font-semibold dark:text-neutral-100">{honor.title}</p>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">{honor.description} ({honor.year})</p>
        </div>
      </div>
    </ScrollReveal>
  ))}
</section>
---
import { projects } from "../../data/projects";
import CollapsibleGrid from "./CollapsibleGrid.svelte";
import ScrollReveal from "./ScrollReveal.svelte";
---

<section class="mb-12">
  <ScrollReveal client:load delay={0}>
    <h2 class="text-3xl font-bold mb-8 dark:text-neutral-100 border-b border-neutral-200 dark:border-neutral-700 pb-2">Projects</h2>
  </ScrollReveal>

  <ScrollReveal client:load delay={50}>
    <CollapsibleGrid client:load items={projects} initialCount={2} type="projects" />
  </ScrollReveal>
</section>

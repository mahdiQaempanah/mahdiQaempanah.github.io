---
import { experience } from "../../data/experience";
import OlympiadSection from "./OlympiadSection.svelte";
import ScrollReveal from "./ScrollReveal.svelte";
---

<section class="mb-12">
  <ScrollReveal client:load delay={0}>
    <h2 class="text-3xl font-bold mb-8 dark:text-neutral-100 border-b border-neutral-200 dark:border-neutral-700 pb-2">Olympiad Teaching</h2>
  </ScrollReveal>

  <ScrollReveal client:load delay={100}>
    <OlympiadSection client:load items={experience.olympiadTeaching} initialCount={3} />
  </ScrollReveal>
</section>